"healthcheck-unauthenticated":
  type: object
  properties:
    ok:
      type: boolean
  required[1]: ok
"healthcheck-authenticated":
  type: object
  properties:
    ok:
      type: boolean
    profileId:
      type: number
  required[1]: ok
"healthcheck-alwaysFail":
"tx-waitForProcessing":
  type: object
  properties:
    processed:
      type: boolean
    status:
      type: string
      enum[4]: not_found,pending,processing,processed
  required[2]: processed,status