"markets-priceHistory":
  type: object
  properties:
    data:
      type: array
      items:
        type: object
        properties:
          timeBucket:
            type: string
          price:
            type: object
            properties:
              trustWei:
                type: integer
                format: int64
              distrustWei:
                type: integer
                format: int64
              trustUsd:
                type: number
              distrustUsd:
                type: number
              totalWei:
                type: integer
                format: int64
              totalUsd:
                type: number
            required[6]: trustWei,distrustWei,trustUsd,distrustUsd,totalWei,totalUsd
            additionalProperties: false
          marketCap:
            type: object
            properties:
              trustWei:
                type: integer
                format: int64
              distrustWei:
                type: integer
                format: int64
              trustUsd:
                type: number
              distrustUsd:
                type: number
              totalWei:
                type: integer
                format: int64
              totalUsd:
                type: number
            required[6]: trustWei,distrustWei,trustUsd,distrustUsd,totalWei,totalUsd
            additionalProperties: false
        required[3]: timeBucket,price,marketCap
        additionalProperties: false
    timeWindow:
      type: string
      enum[8]: 1H,6H,1D,7D,1M,3M,1Y,All
    bucket:
      type: string
      enum[10]: 30 seconds,1 minute,5 minutes,15 minutes,30 minutes,1 hour,2 hours,6 hours,12 hours,1 day
  required[3]: data,timeWindow,bucket
  additionalProperties: false
"markets-simulateBuyVotes":
