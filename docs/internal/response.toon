"internal-getUserByEmbeddedWallet":
  anyOf[2]:
    - type: object
      properties:
        user:
          type: object
          properties:
            id:
              type: number
            profileId:
              anyOf[2]{type}:
                number
                "null"
            displayName:
              type: string
            username:
              anyOf[2]{type}:
                string
                "null"
            avatarUrl:
              type: string
              format: uri
            description:
              anyOf[2]{type}:
                string
                "null"
            score:
              type: number
            status:
              type: string
              enum[3]: ACTIVE,INACTIVE,MERGED
            userkeys:
              type: array
              items:
                type: string
            xpTotal:
              type: number
            xpStreakDays:
              type: number
            xpRemovedDueToAbuse:
              type: boolean
            influenceFactor:
              type: number
            influenceFactorPercentile:
              type: number
            humanVerificationStatus:
              anyOf[2]:
                - type: string
                  enum[3]: REQUESTED,VERIFIED,REVOKED
                - type: "null"
            validatorNftCount:
              type: number
            links:
              type: object
              properties:
                profile:
                  type: string
                  format: uri
                scoreBreakdown:
                  type: string
                  format: uri
              required[2]: profile,scoreBreakdown
              additionalProperties: false
            stats:
              type: object
              properties:
                review:
                  type: object
                  properties:
                    received:
                      type: object
                      properties:
                        negative:
                          type: number
                        neutral:
                          type: number
                        positive:
                          type: number
                      required[3]: negative,neutral,positive
                      additionalProperties: false
                  required[1]: received
                  additionalProperties: false
                vouch:
                  type: object
                  properties:
                    given:
                      type: object
                      properties:
                        amountWeiTotal:
                          type: integer
                          format: int64
                        count:
                          type: number
                      required[2]: amountWeiTotal,count
                      additionalProperties: false
                    received:
                      type: object
                      properties:
                        amountWeiTotal:
                          type: integer
                          format: int64
                        count:
                          type: number
                      required[2]: amountWeiTotal,count
                      additionalProperties: false
                  required[2]: given,received
                  additionalProperties: false
              required[2]: review,vouch
              additionalProperties: false
          required[17]: id,profileId,displayName,username,avatarUrl,description,score,status,userkeys,xpTotal,xpStreakDays,xpRemovedDueToAbuse,influenceFactor,influenceFactorPercentile,validatorNftCount,links,stats
          additionalProperties: false
        profile:
          anyOf[2]:
            - type: object
              properties:
                id:
                  type: integer
                  exclusiveMinimum: 0
                  maximum: 2147483647
                archived:
                  type: boolean
                createdAt:
                  type: number
                updatedAt:
                  type: number
                invitesAvailable:
                  type: number
                invitedBy:
                  type: number
              required[6]: id,archived,createdAt,updatedAt,invitesAvailable,invitedBy
              additionalProperties: false
            - type: "null"
        inviterUser:
          anyOf[2]:
            - type: object
              properties:
                id:
                  type: number
                profileId:
                  anyOf[2]{type}:
                    number
                    "null"
                displayName:
                  type: string
                username:
                  anyOf[2]{type}:
                    string
                    "null"
                avatarUrl:
                  type: string
                  format: uri
                description:
                  anyOf[2]{type}:
                    string
                    "null"
                score:
                  type: number
                status:
                  type: string
                  enum[3]: ACTIVE,INACTIVE,MERGED
                userkeys:
                  type: array
                  items:
                    type: string
                xpTotal:
                  type: number
                xpStreakDays:
                  type: number
                xpRemovedDueToAbuse:
                  type: boolean
                influenceFactor:
                  type: number
                influenceFactorPercentile:
                  type: number
                humanVerificationStatus:
                  anyOf[2]:
                    - type: string
                      enum[3]: REQUESTED,VERIFIED,REVOKED
                    - type: "null"
                validatorNftCount:
                  type: number
                links:
                  type: object
                  properties:
                    profile:
                      type: string
                      format: uri
                    scoreBreakdown:
                      type: string
                      format: uri
                  required[2]: profile,scoreBreakdown
                  additionalProperties: false
                stats:
                  type: object
                  properties:
                    review:
                      type: object
                      properties:
                        received:
                          type: object
                          properties:
                            negative:
                              type: number
                            neutral:
                              type: number
                            positive:
                              type: number
                          required[3]: negative,neutral,positive
                          additionalProperties: false
                      required[1]: received
                      additionalProperties: false
                    vouch:
                      type: object
                      properties:
                        given:
                          type: object
                          properties:
                            amountWeiTotal:
                              type: integer
                              format: int64
                            count:
                              type: number
                          required[2]: amountWeiTotal,count
                          additionalProperties: false
                        received:
                          type: object
                          properties:
                            amountWeiTotal:
                              type: integer
                              format: int64
                            count:
                              type: number
                          required[2]: amountWeiTotal,count
                          additionalProperties: false
                      required[2]: given,received
                      additionalProperties: false
                  required[2]: review,vouch
                  additionalProperties: false
              required[17]: id,profileId,displayName,username,avatarUrl,description,score,status,userkeys,xpTotal,xpStreakDays,xpRemovedDueToAbuse,influenceFactor,influenceFactorPercentile,validatorNftCount,links,stats
              additionalProperties: false
            - type: "null"
        allAddresses:
          type: object
          properties:
            addresses:
              type: array
              items:
                type: string
                description: "Ethereum address (0x-prefixed, 20 bytes)"
            primaryAddress:
              type: string
              description: "Ethereum address (0x-prefixed, 20 bytes)"
            embeddedWallet:
              type: string
              description: "Ethereum address (0x-prefixed, 20 bytes)"
            smartWallet:
              type: string
              description: "Ethereum address (0x-prefixed, 20 bytes)"
          required[1]: addresses
          additionalProperties: false
        attestations:
          type: array
          items:
            type: object
            properties:
              id:
                type: integer
                exclusiveMinimum: 0
                maximum: 9007199254740991
              hash:
                type: string
              archived:
                type: boolean
              profileId:
                type: integer
                exclusiveMinimum: 0
                maximum: 9007199254740991
              service:
                type: string
                enum[5]: discord,farcaster,github,telegram,x.com
              account:
                type: string
              createdAt:
                type: integer
                exclusiveMinimum: 0
                maximum: 9007199254740991
              extra:
                type: object
                properties:
                  username:
                    anyOf[2]{type}:
                      string
                      "null"
                  url:
                    anyOf[2]:
                      - type: string
                        format: uri
                      - type: "null"
                required[2]: username,url
                additionalProperties: false
            required[8]: id,hash,archived,profileId,service,account,createdAt,extra
            additionalProperties: false
        isValidator:
          type: boolean
        validatorAcquiredAt:
          anyOf[2]{type}:
            string
            "null"
      required[7]: user,profile,inviterUser,allAddresses,attestations,isValidator,validatorAcquiredAt
      additionalProperties: false
    - type: "null"
