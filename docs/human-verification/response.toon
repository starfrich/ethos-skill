                  properties:
                    activity:
                      type: string
                      format: uri
                  required[1]: activity
                  additionalProperties: false
              required[15]: id,bondType,statement,amount,amountType,expiration,authorProfileId,archived,archivedAt,archiveReason,createdAt,updatedAt,metadata,author,links
